# Leave blank to use the app's platform-aware default below.
# Android emulator default: http://10.0.2.2:8765
# iOS simulator / web default: http://127.0.0.1:8765
# Physical phone: http://<development-PC-LAN-IP>:8765
EXPO_PUBLIC_API_BASE_URL=

# Optional override. This test build already contains the requested test TMAP key.
EXPO_PUBLIC_TMAP_APP_KEY=
