TASHU_API_TOKEN=replace-with-tashu-token
TMAP_APP_KEY=replace-with-tmap-app-key
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://127.0.0.1:8081
TASHU_DB_PATH=data/tashu.db
MISSION_GPS_RADIUS_METERS=200
REWARD_POINTS_PER_BIKE=100
REWARD_PRIORITY_POINTS_PER_BIKE=50
REWARD_FULL_COMPLETION_BONUS_POINTS=300
STATION_QR_ADMIN_KEY=replace-with-admin-key
STATION_QR_SIGNING_SECRET=replace-with-long-random-secret
STATION_QR_VERIFICATION_TTL_SECONDS=600
QR_CHALLENGE_TTL_SECONDS=120
AUTH_JWT_SECRET=replace-with-long-random-jwt-secret
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=2592000
REWARD_AUTO_APPROVE=false
DEVICE_INTEGRITY_GATEWAY_SECRET=replace-with-integrity-gateway-secret
ALLOW_DEVELOPMENT_INTEGRITY=false
TEST_MODE=true
